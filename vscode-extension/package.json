{
  "name": "mcp-ai-studio",
  "displayName": "MCP AI Studio",
  "description": "Connect, inspect, and call tools on any Streamable HTTP MCP server — right inside VS Code or Windsurf. Configure your server URL, client name, and branding via Settings with no rebuild required.",
  "version": "0.2.0",
  "publisher": "harishkaparwan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harishkaparwan/mcp-ai-studio.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Testing"
  ],
  "icon": "icon.png",
  "keywords": [
    "mcp",
    "model context protocol",
    "ai tools",
    "agent",
    "workbench",
    "llm",
    "tool calling",
    "streamable http",
    "spring ai",
    "fastmcp",
    "inspector",
    "client"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcpAiStudioSidebar",
          "title": "MCP AI Studio",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "mcpAiStudioSidebar": [
        {
          "id": "mcpAiStudio.workbench",
          "name": "Workbench",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "mcpAiStudio.open",
        "title": "MCP AI Studio: Open Workbench"
      }
    ],
    "configuration": {
      "title": "MCP AI Studio",
      "properties": {
        "mcpAiStudio.serverUrl": {
          "type": "string",
          "default": "",
          "description": "MCP server URL. Leave empty to use the default (/mcp) or let the user configure it in the UI."
        },
        "mcpAiStudio.title": {
          "type": "string",
          "default": "",
          "description": "Custom interface title shown in the workbench header."
        },
        "mcpAiStudio.subtitle": {
          "type": "string",
          "default": "",
          "description": "Custom interface subtitle shown below the title."
        },
        "mcpAiStudio.clientName": {
          "type": "string",
          "default": "",
          "description": "MCP client name sent during the initialize handshake."
        },
        "mcpAiStudio.clientVersion": {
          "type": "string",
          "default": "",
          "description": "MCP client version sent during the initialize handshake."
        }
      }
    }
  },
  "scripts": {
    "sync-ui": "node scripts/sync-ui.mjs",
    "package": "vsce package --allow-missing-repository",
    "publish:vscode": "vsce publish --allow-missing-repository",
    "publish:open-vsx": "ovsx publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "ovsx": "^0.10.12"
  },
  "files": [
    "extension.js",
    "icon.png",
    "media",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
