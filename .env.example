# MCP proxy target for Vite dev/preview server
# Requests to /mcp will be proxied to this URL
VITE_MCP_TARGET=http://localhost:8080

# --- Generic app config (all optional) ---
# These are baked in at build time. For runtime config, use:
#   - window.__MCP_CONFIG__  (injected by extension host)
#   - ?mcp=, ?title=, etc.  (URL query params)

# Override the default MCP endpoint shown in the Configurator UI
# Defaults to /mcp (relative, works with the Vite proxy above)
# For Chrome/Windsurf extensions use a full URL: http://localhost:8080/mcp
VITE_MCP_ENDPOINT=/mcp

# Branding overrides
# VITE_TITLE=My MCP AI Studio
# VITE_SUBTITLE=Custom subtitle text
# VITE_CLIENT_NAME=my-client
# VITE_CLIENT_VERSION=1.0.0

# Dev server port (default: 9001)
# VITE_PORT=9001
